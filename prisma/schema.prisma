generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id             String               @id @default(cuid())
  name           String
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  creditNotes    CreditNote[]
  customers      Customer[]
  modules        OrganisationModule[]
  categories     ProductCategory[]
  products       Product[]
  purchaseOrders PurchaseOrder[]
  salesOrders    SalesOrder[]
  suppliers      Supplier[]
  warehouses     Warehouse[]

  @@map("organizations")
}

model OrganisationModule {
  id             String       @id @default(cuid())
  organizationId String
  moduleKey      String
  enabledAt      DateTime     @default(now())
  enabledById    String
  enabledBy      Employee     @relation("ModuleEnabledBy", fields: [enabledById], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, moduleKey])
  @@map("organisation_modules")
}

model Warehouse {
  id                 String              @id @default(cuid())
  name               String
  address            String?
  organizationId     String
  archivedAt         DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  creditNotes        CreditNote[]
  deliveryNotes      DeliveryNote[]
  employees          Employee[]
  goodsReceipts      GoodsReceipt[]
  inventoryBalances  InventoryBalance[]
  inventoryMovements InventoryMovement[]
  invoices           Invoice[]
  notifications      Notification[]
  purchaseOrders     PurchaseOrder[]
  salesOrders        SalesOrder[]
  transfersIn        StockTransfer[]     @relation("TransferDestination")
  transfersOut       StockTransfer[]     @relation("TransferSource")
  warehouseRoles     WarehouseRole[]
  organization       Organization        @relation(fields: [organizationId], references: [id])

  @@map("warehouses")
}

model Employee {
  id                      String               @id @default(cuid())
  name                    String
  email                   String               @unique
  passwordHash            String
  warehouseId             String
  warehouseRoleId         String?
  locale                  String               @default("en")
  archivedAt              DateTime?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  auditLogs               AuditLog[]           @relation("AuditActor")
  creditNotesCreated      CreditNote[]         @relation("CreditNoteCreatedBy")
  deliveryNotesDispatched DeliveryNote[]       @relation("DeliveryNoteDispatchedBy")
  warehouse               Warehouse            @relation(fields: [warehouseId], references: [id])
  warehouseRole           WarehouseRole?       @relation(fields: [warehouseRoleId], references: [id])
  goodsReceiptsReceived   GoodsReceipt[]       @relation("GoodsReceiptReceivedBy")
  inventoryMovements      InventoryMovement[]  @relation("MovementActor")
  invoices                Invoice[]            @relation("InvoiceActor")
  enabledModules          OrganisationModule[] @relation("ModuleEnabledBy")
  payments                Payment[]            @relation("PaymentActor")
  purchaseOrdersCreated   PurchaseOrder[]      @relation("PurchaseOrderCreatedBy")
  salesOrdersCreated      SalesOrder[]         @relation("SalesOrderCreatedBy")
  stockTransfers          StockTransfer[]      @relation("TransferActor")

  @@map("employees")
}

model RoleTemplate {
  id             String          @id @default(cuid())
  name           String          @unique
  description    String?
  createdAt      DateTime        @default(now())
  warehouseRoles WarehouseRole[]

  @@map("role_templates")
}

model WarehouseRole {
  id             String                    @id @default(cuid())
  warehouseId    String
  roleTemplateId String
  employees      Employee[]
  permissions    WarehouseRolePermission[]
  roleTemplate   RoleTemplate              @relation(fields: [roleTemplateId], references: [id])
  warehouse      Warehouse                 @relation(fields: [warehouseId], references: [id])

  @@unique([warehouseId, roleTemplateId])
  @@map("warehouse_roles")
}

model Permission {
  id                       String                    @id @default(cuid())
  code                     String                    @unique
  description              String?
  warehouseRolePermissions WarehouseRolePermission[]

  @@map("permissions")
}

model WarehouseRolePermission {
  id              String        @id @default(cuid())
  warehouseRoleId String
  permissionId    String
  permission      Permission    @relation(fields: [permissionId], references: [id])
  warehouseRole   WarehouseRole @relation(fields: [warehouseRoleId], references: [id])

  @@unique([warehouseRoleId, permissionId])
  @@map("warehouse_role_permissions")
}

model ProductUnit {
  id                 String                  @id @default(cuid())
  name               String
  symbol             String                  @unique
  isBase             Boolean                 @default(false)
  archivedAt         DateTime?
  creditNoteLines    CreditNoteLine[]
  deliveryNoteLines  DeliveryNoteLine[]
  goodsReceiptLines  GoodsReceiptLine[]
  inventoryMovements InventoryMovement[]
  invoiceLines       InvoiceLine[]
  conversionsFrom    ProductUnitConversion[] @relation("ConversionFromUnit")
  conversionsTo      ProductUnitConversion[] @relation("ConversionToUnit")
  products           Product[]
  purchaseOrderLines PurchaseOrderLine[]
  salesOrderLines    SalesOrderLine[]
  stockTransferLines StockTransferLine[]

  @@map("product_units")
}

model ProductCategory {
  id             String       @id @default(cuid())
  name           String
  organizationId String
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])
  products       Product[]

  @@map("product_categories")
}

model Product {
  id                 String                  @id @default(cuid())
  name               String
  sku                String                  @unique
  description        String?
  categoryId         String?
  defaultUnitId      String
  organizationId     String
  barcode            String?
  lowStockThreshold  Int?
  archivedAt         DateTime?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  creditNoteLines    CreditNoteLine[]
  deliveryNoteLines  DeliveryNoteLine[]
  goodsReceiptLines  GoodsReceiptLine[]
  inventoryBalances  InventoryBalance[]
  inventoryMovements InventoryMovement[]
  invoiceLines       InvoiceLine[]
  conversions        ProductUnitConversion[]
  category           ProductCategory?        @relation(fields: [categoryId], references: [id])
  defaultUnit        ProductUnit             @relation(fields: [defaultUnitId], references: [id])
  organization       Organization            @relation(fields: [organizationId], references: [id])
  purchaseOrderLines PurchaseOrderLine[]
  salesOrderLines    SalesOrderLine[]
  stockTransferLines StockTransferLine[]

  @@map("products")
}

model ProductUnitConversion {
  id         String      @id @default(cuid())
  fromUnitId String
  toUnitId   String
  factor     Decimal     @db.Decimal(20, 10)
  productId  String?
  fromUnit   ProductUnit @relation("ConversionFromUnit", fields: [fromUnitId], references: [id])
  product    Product?    @relation(fields: [productId], references: [id])
  toUnit     ProductUnit @relation("ConversionToUnit", fields: [toUnitId], references: [id])

  @@map("product_unit_conversions")
}

model InventoryMovement {
  id            String       @id @default(cuid())
  warehouseId   String
  productId     String
  unitId        String
  quantity      Decimal      @db.Decimal(20, 6)
  baseQuantity  Decimal      @db.Decimal(20, 6)
  movementType  MovementType
  referenceId   String?
  referenceType String?
  actorId       String
  notes         String?
  createdAt     DateTime     @default(now())
  actor         Employee     @relation("MovementActor", fields: [actorId], references: [id])
  product       Product      @relation(fields: [productId], references: [id])
  unit          ProductUnit  @relation(fields: [unitId], references: [id])
  warehouse     Warehouse    @relation(fields: [warehouseId], references: [id])

  @@map("inventory_movements")
}

model InventoryBalance {
  id              String    @id @default(cuid())
  warehouseId     String
  productId       String
  currentQuantity Decimal   @db.Decimal(20, 6)
  updatedAt       DateTime  @updatedAt
  reorderPoint    Int?
  reorderQty      Int?
  product         Product   @relation(fields: [productId], references: [id])
  warehouse       Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([warehouseId, productId])
  @@map("inventory_balances")
}

model StockTransfer {
  id                     String              @id @default(cuid())
  sourceWarehouseId      String
  destinationWarehouseId String
  transferredById        String
  note                   String?
  createdAt              DateTime            @default(now())
  lines                  StockTransferLine[]
  destinationWarehouse   Warehouse           @relation("TransferDestination", fields: [destinationWarehouseId], references: [id])
  sourceWarehouse        Warehouse           @relation("TransferSource", fields: [sourceWarehouseId], references: [id])
  transferredBy          Employee            @relation("TransferActor", fields: [transferredById], references: [id])

  @@map("stock_transfers")
}

model StockTransferLine {
  id              String        @id @default(cuid())
  transferId      String
  productId       String
  unitId          String
  displayQuantity Decimal       @db.Decimal(20, 6)
  baseQuantity    Decimal       @db.Decimal(20, 6)
  product         Product       @relation(fields: [productId], references: [id])
  transfer        StockTransfer @relation(fields: [transferId], references: [id])
  unit            ProductUnit   @relation(fields: [unitId], references: [id])

  @@map("stock_transfer_lines")
}

model Customer {
  id             String        @id @default(cuid())
  name           String
  email          String?
  phone          String?
  address        String?
  organizationId String
  archivedAt     DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  creditLimit    Decimal?      @db.Decimal(20, 2)
  paymentTerms   PaymentTerms?
  organization   Organization  @relation(fields: [organizationId], references: [id])
  invoices       Invoice[]
  salesOrders    SalesOrder[]

  @@map("customers")
}

model Supplier {
  id             String          @id @default(cuid())
  name           String
  email          String?
  phone          String?
  address        String?
  organizationId String
  archivedAt     DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  paymentTerms   PaymentTerms?
  invoices       Invoice[]
  purchaseOrders PurchaseOrder[]
  organization   Organization    @relation(fields: [organizationId], references: [id])

  @@map("suppliers")
}

model Invoice {
  id              String         @id @default(cuid())
  type            InvoiceType
  status          InvoiceStatus  @default(DRAFT)
  warehouseId     String
  customerId      String?
  supplierId      String?
  totalAmount     Decimal        @db.Decimal(20, 2)
  notes           String?
  actorId         String
  confirmedAt     DateTime?
  cancelledAt     DateTime?
  deliveryDate    DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  purchaseOrderId String?
  taxAmount       Decimal?       @db.Decimal(20, 2)
  dueDate         DateTime?
  deliveryNoteId  String?        @unique
  creditNotes     CreditNote[]
  deliveryNotes   DeliveryNote[]
  goodsReceipts   GoodsReceipt[]
  lines           InvoiceLine[]
  actor           Employee       @relation("InvoiceActor", fields: [actorId], references: [id])
  customer        Customer?      @relation(fields: [customerId], references: [id])
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  supplier        Supplier?      @relation(fields: [supplierId], references: [id])
  warehouse       Warehouse      @relation(fields: [warehouseId], references: [id])
  payments        Payment[]
  deliveryNote    DeliveryNote?  @relation("InvoiceDeliveryNote", fields: [deliveryNoteId], references: [id])

  @@map("invoices")
}

model InvoiceLine {
  id         String      @id @default(cuid())
  invoiceId  String
  productId  String
  unitId     String
  quantity   Decimal     @db.Decimal(20, 6)
  unitPrice  Decimal     @db.Decimal(20, 2)
  totalPrice Decimal     @db.Decimal(20, 2)
  discount   Decimal?    @db.Decimal(5, 2)
  invoice    Invoice     @relation(fields: [invoiceId], references: [id])
  product    Product     @relation(fields: [productId], references: [id])
  unit       ProductUnit @relation(fields: [unitId], references: [id])

  @@map("invoice_lines")
}

model Payment {
  id        String        @id @default(cuid())
  invoiceId String
  amount    Decimal       @db.Decimal(20, 2)
  method    PaymentMethod
  paidAt    DateTime
  notes     String?
  actorId   String
  actor     Employee      @relation("PaymentActor", fields: [actorId], references: [id])
  invoice   Invoice       @relation(fields: [invoiceId], references: [id])

  @@map("payments")
}

model PurchaseOrder {
  id                   String              @id @default(cuid())
  organizationId       String
  warehouseId          String
  supplierId           String
  status               PurchaseOrderStatus @default(DRAFT)
  expectedDeliveryDate DateTime?
  note                 String?
  createdById          String
  sentAt               DateTime?
  receivedAt           DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  receipts             GoodsReceipt[]
  invoices             Invoice[]
  lines                PurchaseOrderLine[]
  createdBy            Employee            @relation("PurchaseOrderCreatedBy", fields: [createdById], references: [id])
  organization         Organization        @relation(fields: [organizationId], references: [id])
  supplier             Supplier            @relation(fields: [supplierId], references: [id])
  warehouse            Warehouse           @relation(fields: [warehouseId], references: [id])

  @@map("purchase_orders")
}

model PurchaseOrderLine {
  id                   String             @id @default(cuid())
  purchaseOrderId      String
  productId            String
  unitId               String
  displayQuantity      Decimal            @db.Decimal(20, 6)
  baseQuantity         Decimal            @db.Decimal(20, 6)
  unitCost             Decimal            @db.Decimal(20, 2)
  receivedBaseQuantity Decimal            @default(0) @db.Decimal(20, 6)
  goodsReceiptLines    GoodsReceiptLine[]
  product              Product            @relation(fields: [productId], references: [id])
  purchaseOrder        PurchaseOrder      @relation(fields: [purchaseOrderId], references: [id])
  unit                 ProductUnit        @relation(fields: [unitId], references: [id])

  @@map("purchase_order_lines")
}

model GoodsReceipt {
  id              String             @id @default(cuid())
  purchaseOrderId String?
  invoiceId       String?
  warehouseId     String
  receivedById    String
  note            String?
  createdAt       DateTime           @default(now())
  lines           GoodsReceiptLine[]
  purchaseOrder   PurchaseOrder?     @relation(fields: [purchaseOrderId], references: [id])
  invoice         Invoice?           @relation(fields: [invoiceId], references: [id])
  receivedBy      Employee           @relation("GoodsReceiptReceivedBy", fields: [receivedById], references: [id])
  warehouse       Warehouse          @relation(fields: [warehouseId], references: [id])

  @@map("goods_receipts")
}

model GoodsReceiptLine {
  id                  String             @id @default(cuid())
  goodsReceiptId      String
  purchaseOrderLineId String?
  productId           String
  unitId              String
  displayQuantity     Decimal            @db.Decimal(20, 6)
  baseQuantity        Decimal            @db.Decimal(20, 6)
  goodsReceipt        GoodsReceipt       @relation(fields: [goodsReceiptId], references: [id])
  product             Product            @relation(fields: [productId], references: [id])
  purchaseOrderLine   PurchaseOrderLine? @relation(fields: [purchaseOrderLineId], references: [id])
  unit                ProductUnit        @relation(fields: [unitId], references: [id])

  @@map("goods_receipt_lines")
}

model CreditNote {
  id                String           @id @default(cuid())
  type              CreditNoteType
  status            CreditNoteStatus @default(DRAFT)
  organizationId    String
  warehouseId       String
  originalInvoiceId String
  note              String?
  createdById       String
  confirmedAt       DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  lines             CreditNoteLine[]
  createdBy         Employee         @relation("CreditNoteCreatedBy", fields: [createdById], references: [id])
  organization      Organization     @relation(fields: [organizationId], references: [id])
  originalInvoice   Invoice          @relation(fields: [originalInvoiceId], references: [id])
  warehouse         Warehouse        @relation(fields: [warehouseId], references: [id])

  @@map("credit_notes")
}

model CreditNoteLine {
  id              String      @id @default(cuid())
  creditNoteId    String
  productId       String
  unitId          String
  displayQuantity Decimal     @db.Decimal(20, 6)
  baseQuantity    Decimal     @db.Decimal(20, 6)
  unitPrice       Decimal     @db.Decimal(20, 2)
  creditNote      CreditNote  @relation(fields: [creditNoteId], references: [id])
  product         Product     @relation(fields: [productId], references: [id])
  unit            ProductUnit @relation(fields: [unitId], references: [id])

  @@map("credit_note_lines")
}

model SalesOrder {
  id                   String           @id @default(cuid())
  organizationId       String
  warehouseId          String
  customerId           String
  status               SalesOrderStatus @default(DRAFT)
  expectedDeliveryDate DateTime?
  note                 String?
  createdById          String
  confirmedAt          DateTime?
  fulfilledAt          DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  deliveryNotes        DeliveryNote[]
  lines                SalesOrderLine[]
  createdBy            Employee         @relation("SalesOrderCreatedBy", fields: [createdById], references: [id])
  customer             Customer         @relation(fields: [customerId], references: [id])
  organization         Organization     @relation(fields: [organizationId], references: [id])
  warehouse            Warehouse        @relation(fields: [warehouseId], references: [id])

  @@map("sales_orders")
}

model SalesOrderLine {
  id                    String             @id @default(cuid())
  salesOrderId          String
  productId             String
  unitId                String
  displayQuantity       Decimal            @db.Decimal(20, 6)
  baseQuantity          Decimal            @db.Decimal(20, 6)
  unitPrice             Decimal            @db.Decimal(20, 2)
  discount              Decimal?           @db.Decimal(5, 2)
  deliveredBaseQuantity Decimal            @default(0) @db.Decimal(20, 6)
  deliveryNoteLines     DeliveryNoteLine[]
  product               Product            @relation(fields: [productId], references: [id])
  salesOrder            SalesOrder         @relation(fields: [salesOrderId], references: [id])
  unit                  ProductUnit        @relation(fields: [unitId], references: [id])

  @@map("sales_order_lines")
}

model DeliveryNote {
  id              String             @id @default(cuid())
  salesOrderId    String?
  invoiceId       String?
  warehouseId     String
  dispatchedById  String
  note            String?
  createdAt       DateTime           @default(now())
  lines           DeliveryNoteLine[]
  dispatchedBy    Employee           @relation("DeliveryNoteDispatchedBy", fields: [dispatchedById], references: [id])
  salesOrder      SalesOrder?        @relation(fields: [salesOrderId], references: [id])
  invoice         Invoice?           @relation(fields: [invoiceId], references: [id])
  warehouse       Warehouse          @relation(fields: [warehouseId], references: [id])
  salesInvoice    Invoice?           @relation("InvoiceDeliveryNote")

  @@map("delivery_notes")
}

model DeliveryNoteLine {
  id               String          @id @default(cuid())
  deliveryNoteId   String
  salesOrderLineId String?
  productId        String
  unitId           String
  displayQuantity  Decimal         @db.Decimal(20, 6)
  baseQuantity     Decimal         @db.Decimal(20, 6)
  deliveryNote     DeliveryNote    @relation(fields: [deliveryNoteId], references: [id])
  product          Product         @relation(fields: [productId], references: [id])
  salesOrderLine   SalesOrderLine? @relation(fields: [salesOrderLineId], references: [id])
  unit             ProductUnit     @relation(fields: [unitId], references: [id])

  @@map("delivery_note_lines")
}

model Notification {
  id          String    @id @default(cuid())
  warehouseId String
  type        String
  payload     Json
  readAt      DateTime?
  createdAt   DateTime  @default(now())
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  @@map("notifications")
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  action     String
  entityType String
  entityId   String
  before     Json?
  after      Json?
  ipAddress  String?
  createdAt  DateTime @default(now())
  actor      Employee @relation("AuditActor", fields: [actorId], references: [id])

  @@map("audit_logs")
}

enum MovementType {
  PURCHASE_IN
  SALE_OUT
  TRANSFER_IN
  TRANSFER_OUT
  ADJUSTMENT
  RETURN_IN
  RETURN_OUT
}

enum InvoiceStatus {
  DRAFT
  CONFIRMED
  CANCELLED
}

enum InvoiceType {
  PURCHASE
  SALE
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
}

enum PaymentTerms {
  COD
  NET_15
  NET_30
  NET_60
  NET_90
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  PARTIAL
  RECEIVED
  CANCELLED
  CLOSED
}

enum CreditNoteType {
  PURCHASE
  SALE
}

enum CreditNoteStatus {
  DRAFT
  CONFIRMED
  CANCELLED
}

enum SalesOrderStatus {
  DRAFT
  CONFIRMED
  PARTIAL
  FULFILLED
  CANCELLED
  CLOSED
}
